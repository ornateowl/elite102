{
    "name": "Python 3",
    "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.shell.linux": "/bin/bash",
                "python.defaultInterpreterPath": "/workspaces/elite102/.venv/bin/python",
                "python.venvPath": "/workspaces/elite102",
                "python.terminal.executeInFileDir": true
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "qwtel.sqlite-viewer"
            ]
        }
    },
    "mounts": [
        "source=${localWorkspaceFolder}/data,target=/home/vscode/data,type=bind,consistency=cached"
    ],
    "forwardPorts": [],
    "postCreateCommand": "apt-get update && apt-get install -y sqlite3 libsqlite3-dev && python -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt && echo 'source /workspaces/elite102/.venv/bin/activate' >> ~/.bashrc",
    "remoteUser": "vscode"
}